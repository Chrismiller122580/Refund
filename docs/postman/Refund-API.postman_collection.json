{
  "info": {
    "name": "Refund Calculators API",
    "description": "VSC and Gap refund API with cookie and API key auth. Routes use freedom/gap identifiers.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "https://refund-mocha-psi.vercel.app" },
    { "key": "email", "value": "admin@example.com" },
    { "key": "password", "value": "change-me" },
    { "key": "apiKey", "value": "" },
    { "key": "caseId", "value": "" },
    { "key": "userId", "value": "" },
    { "key": "apiKeyId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{apiKey}}", "disabled": true }
            ],
            "url": "{{baseUrl}}/api/auth/me"
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/logout"
          }
        }
      ]
    },
    {
      "name": "Calculations",
      "item": [
        {
          "name": "Freedom Calculate",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{apiKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"startMileage\": 101520,\n  \"endMileage\": 204145,\n  \"contractTermMiles\": 5000,\n  \"contractTermDays\": 1095,\n  \"startDate\": \"2024-06-25\",\n  \"endDate\": \"2025-10-29\",\n  \"cost\": 1928,\n  \"markup\": 1050,\n  \"deductible\": 50,\n  \"approvedClaimAmount\": 0,\n  \"unlimitedMileage\": false\n}"
            },
            "url": "{{baseUrl}}/api/calculate/freedom"
          }
        },
        {
          "name": "Freedom Unlimited Mileage",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{apiKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"contractTermDays\": 1095,\n  \"startDate\": \"2024-06-25\",\n  \"endDate\": \"2025-10-29\",\n  \"cost\": 1928,\n  \"markup\": 1050,\n  \"deductible\": 50,\n  \"approvedClaimAmount\": 0,\n  \"unlimitedMileage\": true\n}"
            },
            "url": "{{baseUrl}}/api/calculate/freedom"
          }
        },
        {
          "name": "GAP Calculate",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{apiKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"contractTermDays\": 1825,\n  \"startDate\": \"2023-03-04\",\n  \"endDate\": \"2026-02-27\",\n  \"fwCost\": 103,\n  \"retailCost\": 855,\n  \"deductible\": 50,\n  \"approvedClaimAmount\": 0\n}"
            },
            "url": "{{baseUrl}}/api/calculate/gap"
          }
        }
      ]
    },
    {
      "name": "Cases",
      "item": [
        {
          "name": "List Cases",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{apiKey}}" }],
            "url": "{{baseUrl}}/api/cases?type=freedom"
          }
        },
        {
          "name": "Create Case",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{apiKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Postman Test Case\",\n  \"type\": \"freedom\",\n  \"inputs\": {\n    \"startMileage\": 0,\n    \"endMileage\": 0,\n    \"contractTermMiles\": 5000,\n    \"contractTermDays\": 1095,\n    \"startDate\": \"2024-06-25\",\n    \"endDate\": \"2025-10-29\",\n    \"cost\": 1928,\n    \"markup\": 1050,\n    \"deductible\": 50,\n    \"approvedClaimAmount\": 0,\n    \"unlimitedMileage\": false\n  }\n}"
            },
            "url": "{{baseUrl}}/api/cases"
          }
        },
        {
          "name": "Update Case",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{apiKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Postman Test Case (updated)\",\n  \"inputs\": {\n    \"startMileage\": 0,\n    \"endMileage\": 0,\n    \"contractTermMiles\": 5000,\n    \"contractTermDays\": 1095,\n    \"startDate\": \"2024-06-25\",\n    \"endDate\": \"2025-10-29\",\n    \"cost\": 1928,\n    \"markup\": 1050,\n    \"deductible\": 50,\n    \"approvedClaimAmount\": 0,\n    \"unlimitedMileage\": false\n  }\n}"
            },
            "url": "{{baseUrl}}/api/cases/{{caseId}}"
          }
        },
        {
          "name": "Delete Case",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{apiKey}}" }],
            "url": "{{baseUrl}}/api/cases/{{caseId}}"
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "List Users",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{apiKey}}" }],
            "url": "{{baseUrl}}/api/admin/users"
          }
        },
        {
          "name": "Create User",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{apiKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"integration@example.com\",\n  \"password\": \"change-me-strong\",\n  \"role\": \"user\"\n}"
            },
            "url": "{{baseUrl}}/api/admin/users"
          }
        },
        {
          "name": "List API Keys",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{apiKey}}" }],
            "url": "{{baseUrl}}/api/admin/api-keys"
          }
        },
        {
          "name": "Create API Key",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{apiKey}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"name\": \"External Integration\"\n}"
            },
            "url": "{{baseUrl}}/api/admin/api-keys"
          }
        },
        {
          "name": "Revoke API Key",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{apiKey}}" }],
            "url": "{{baseUrl}}/api/admin/api-keys/{{apiKeyId}}"
          }
        }
      ]
    }
  ]
}